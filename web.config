<configuration>
    <system.webServer>
        <!-- Remove WebDAV module that interferes with PUT/DELETE -->
        <modules>
            <remove name="WebDAVModule" />
        </modules>

        <handlers>
            <!-- Remove WebDAV handler -->
            <remove name="WebDAV" />
            <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" requireAccess="Script" />
        </handlers>

        <!-- Explicitly allow HTTP methods -->
        <security>
            <requestFiltering>
                <verbs allowUnlisted="true">
                    <add verb="PUT" allowed="true" />
                    <add verb="PATCH" allowed="true" />
                </verbs>
            </requestFiltering>
        </security>

        <httpPlatform stdoutLogEnabled="true" stdoutLogFile=".\logs\node.log" startupTimeLimit="20" processPath="C:\Program Files\nodejs\node.exe" arguments=".\node_modules\next\dist\bin\next start">
            <environmentVariables>
                <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
                <environmentVariable name="NODE_ENV" value="Production" />
            </environmentVariables>
        </httpPlatform>

        <rewrite>
            <rules>
                <rule name="http to https" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTPS}" pattern="^OFF$" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" />
                </rule>
                <rule name="Redirect www to non-www" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTP_HOST}" pattern="^www\.khabargaon\.com$" />
                    </conditions>
                    <action type="Redirect" url="https://khabargaon.com/{R:0}" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
